{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "isGuest": { "type": "boolean" },
        "favorites": { "type": "array", "items": { "type": "integer" } },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "isGuest"]
    },
    "SongStat": {
      "title": "Song Statistics",
      "description": "Global view statistics for a song",
      "type": "object",
      "properties": {
        "songId": { "type": "integer" },
        "viewCount": { "type": "integer" },
        "lastViewed": { "type": "string", "format": "date-time" }
      },
      "required": ["songId", "viewCount"]
    },
    "AppStat": {
      "title": "App Statistics",
      "description": "Global application usage statistics",
      "type": "object",
      "properties": {
        "openCount": { "type": "integer" },
        "lastOpened": { "type": "string", "format": "date-time" }
      },
      "required": ["openCount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/song_views/{songId}": {
      "schema": "SongStat",
      "description": "Global view counts for songs"
    },
    "/app_usage/global": {
      "schema": "AppStat",
      "description": "Global app usage metrics"
    }
  }
}
